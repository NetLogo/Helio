#!/usr/bin/env bash
set -e

branch="$(git symbolic-ref --short HEAD)"

if [ "$branch" = "main" ]; then
  if [ -n "${IGNORE_BRANCH_PROTECTION_RULES}" = "1" ]; then
    echo "Direct pushes to main are blocked."
    echo "Set IGNORE_BRANCH_PROTECTION_RULES=1 to bypass intentionally."
    exit 1
  fi
fi

echo "Running pre-push checks…"

if [ "${IGNORE_PRE_PUSH}" = "1" ]; then
  echo "Skipping pre-push checks."
  exit 0
fi

yarn run pre-push
