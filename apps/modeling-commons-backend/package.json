{
  "name": "modeling-commons-backend",
  "version": "0.0.0",
  "type": "module",
  "imports": {
    "#src/*": "./src/*",
    "#modules/*": "./src/modules/*",
    "#tests/*": "./tests/*",
    "#prisma/*": {
      "types": "./generated/prisma/*.d.ts",
      "default": "./generated/prisma/*.js"
    }
  },
  "license": "UNLICENSED",
  "scripts": {
    "create:env": "node -e \"const fs = require('fs'); if (fs.existsSync('.env.example')) { if (!fs.existsSync('.env')) { fs.copyFileSync('.env.example', '.env'); console.log('✓ .env created from .env.example'); } else { console.log('✓ .env already exists'); } } else { console.log('⚠ .env.example not found'); }\"",
    "init": "yarn run create:env && yarn run db:generate",
    "dev": "yarn run app & yarn run db",
    "app": "node --env-file=.env --import ./src/instrumentation.ts --watch src/index.ts | pino-pretty -clSt",
    "app:prod": "node --env-file=.env --import ./src/instrumentation.ts ./src/index.ts",
    "svc": "docker-compose -f docker-compose.dev.yml up",
    "svc:full": "docker-compose -f docker-compose.dev.yml --profile optional up",
    "svc:down": "docker-compose -f docker-compose.dev.yml down",
    "generate:types": "bash scripts/generate-types.sh",
    "test": "yarn run test:unit && yarn run test:e2e",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run",
    "test:e2e": "FASTIFY_AUTOLOAD_TYPESCRIPT=1 cucumber-js --exit",
    "format": "prettier --write .",
    "lint": "eslint . --max-warnings 0",
    "check-types": "tsc --noEmit",
    "check": "yarn run check-types && yarn run deps:validate",
    "refresh": "yarn run db:generate && yarn run generate:types",
    "prisma": "prisma",
    "db:migrate": "prisma migrate deploy",
    "db:generate": "prisma generate",
    "db:migrate:dev": "prisma migrate dev",
    "db:seed": "prisma db seed",
    "deps:validate": "depcruise src --config .dependency-cruiser.cjs --output-type err-long",
    "deps:graph": "depcruise src --include-only \"^src\" --config --output-type dot | dot -T svg > doc/dependency-graph.svg"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@adminjs/fastify": "^4.2.0",
    "@adminjs/prisma": "^5.0.4",
    "@adminjs/sql": "^2.2.6",
    "@better-auth/passkey": "^1.5.6",
    "@fastify/autoload": "6.3.1",
    "@fastify/awilix": "8.2.0",
    "@fastify/cors": "11.2.0",
    "@fastify/helmet": "13.0.2",
    "@fastify/multipart": "^9.4.0",
    "@fastify/otel": "0.17.1",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/request-context": "6.2.1",
    "@fastify/static": "^9.0.0",
    "@fastify/swagger": "9.7.0",
    "@fastify/swagger-ui": "5.2.5",
    "@fastify/type-provider-typebox": "6.1.0",
    "@fastify/under-pressure": "9.0.3",
    "@opentelemetry/api": "1.9.0",
    "@opentelemetry/instrumentation": "0.213.0",
    "@opentelemetry/instrumentation-http": "0.213.0",
    "@opentelemetry/sdk-node": "0.213.0",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "latest",
    "@repo/modeling-commons-shared": "0.0.0",
    "@scalar/fastify-api-reference": "^1.49.7",
    "adminjs": "^7.8.17",
    "ajv": "8.18.0",
    "ajv-formats": "3.0.1",
    "awilix": "13.0.3",
    "better-auth": "^1.5.6",
    "env-schema": "7.0.0",
    "fastify": "5.8.4",
    "fastify-plugin": "5.1.0",
    "file-type": "^22.0.0",
    "pg": "^8.20.0",
    "pg-boss": "^12.14.0",
    "typebox": "1.1.6"
  },
  "devDependencies": {
    "@cucumber/cucumber": "12.7.0",
    "@cucumber/html-formatter": "23.0.0",
    "@cucumber/messages": "32.2.0",
    "@cucumber/pretty-formatter": "3.2.0",
    "@repo/eslint-config": "0.0.0",
    "@types/k6": "1.6.0",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.20.0",
    "@typescript-eslint/eslint-plugin": "8.45.0",
    "@typescript-eslint/parser": "8.45.0",
    "c8": "10.1.3",
    "dependency-cruiser": "17.3.9",
    "dom-parser": "^1.1.5",
    "eslint": "^9.31.0",
    "openapi-typescript": "7.13.0",
    "pino-pretty": "13.1.3",
    "prettier": "^3.6.2",
    "prisma": "latest",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.2"
  }
}
