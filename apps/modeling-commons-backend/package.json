{
  "name": "modeling-commons-backend",
  "version": "0.0.0",
  "type": "module",
  "imports": {
    "#src/*": "./src/*",
    "#tests/*": "./tests/*"
  },
  "license": "UNLICENSED",
  "scripts": {
    "create:env": "node -e \"require('fs').copyFileSync('.env.example', '.env', require('fs').constants.COPYFILE_EXCL)\"",
    "dev": "node --env-file=.env --import ./src/instrumentation.ts --watch src/index.ts | pino-pretty -clSt",
    "dev:prod": "node --env-file=.env --import ./src/instrumentation.ts ./src/index.ts",
    "test": "yarn run test:unit",
    "test:coverage": "c8 node --test src/**/*.spec.ts",
    "test:unit": "node --test src/**/*.spec.ts",
    "test:e2e": "FASTIFY_AUTOLOAD_TYPESCRIPT=1 cucumber-js --exit",
    "format": "prettier --write .",
    "lint": "eslint . --max-warnings 0",
    "check-types": "tsc --noEmit",
    "db:migrate": "prisma migrate deploy",
    "db:seed:users": "k6 run ./tests/user/create-user/create-user.k6.ts",
    "prisma": "prisma",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:seed": "prisma db seed",
    "deps:validate": "depcruise src --config .dependency-cruiser.cjs --output-type err-long",
    "deps:graph": "depcruise src --include-only \"^src\" --config --output-type dot | dot -T svg > doc/dependency-graph.svg"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@fastify/autoload": "6.3.1",
    "@fastify/awilix": "8.2.0",
    "@fastify/cors": "11.2.0",
    "@fastify/helmet": "13.0.2",
    "@fastify/otel": "0.17.1",
    "@fastify/request-context": "6.2.1",
    "@fastify/swagger": "9.7.0",
    "@fastify/swagger-ui": "5.2.5",
    "@fastify/type-provider-typebox": "6.1.0",
    "@fastify/under-pressure": "9.0.3",
    "@opentelemetry/api": "1.9.0",
    "@opentelemetry/instrumentation": "0.213.0",
    "@opentelemetry/instrumentation-http": "0.213.0",
    "@opentelemetry/sdk-node": "0.213.0",
    "@prisma/client": "latest",
    "@repo/modeling-commons-shared": "0.0.0",
    "ajv": "8.18.0",
    "ajv-formats": "3.0.1",
    "awilix": "13.0.3",
    "better-auth": "^1.5.6",
    "env-schema": "7.0.0",
    "fastify": "5.8.4",
    "fastify-plugin": "5.1.0",
    "pg": "^8.20.0",
    "typebox": "1.1.6"
  },
  "devDependencies": {
    "@cucumber/cucumber": "12.7.0",
    "@cucumber/html-formatter": "23.0.0",
    "@cucumber/messages": "32.2.0",
    "@cucumber/pretty-formatter": "3.2.0",
    "@repo/eslint-config": "0.0.0",
    "@types/k6": "1.6.0",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.20.0",
    "@typescript-eslint/eslint-plugin": "8.45.0",
    "@typescript-eslint/parser": "8.45.0",
    "c8": "10.1.3",
    "dependency-cruiser": "17.3.9",
    "eslint": "^9.31.0",
    "openapi-typescript": "7.13.0",
    "pino-pretty": "13.1.3",
    "prettier": "^3.6.2",
    "prisma": "latest",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  }
}
