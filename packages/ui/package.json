{
  "name": "@repo/ui",
  "version": "0.0.0",
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist"
  ],
  "exports": {
    "./styles.scss": "./dist/styles.scss",
    "./*": {
      "types": "./dist/*.d.ts",
      "default": "./dist/*.js"
    },
    "./**/*": {
      "types": "./dist/**/*.d.ts",
      "default": "./dist/**/*.js"
    },
    "./assets/*": "./assets/*"
  },
  "license": "MIT",
  "scripts": {
    "build:styles": "tailwindcss -i ./src/styles.scss -o ./dist/styles.scss",
    "build:components": "tsc && tsc-alias && npm run copy:scss",
    "copy:scss": "find src -name '*.scss' -not -name 'styles.scss' | while read file; do mkdir -p \"dist/$(dirname \"${file#src/}\")\"; cp \"$file\" \"dist/${file#src/}\"; done",
    "check-types": "tsc --noEmit",
    "dev": "npm run dev:components & npm run dev:styles & npm run dev:scss",
    "dev:styles": "tailwindcss -i ./src/styles.scss -o ./dist/styles.scss --watch",
    "dev:components": "tsc --watch & tsc-alias --watch",
    "dev:scss": "chokidar 'src/**/*.scss' -c 'npm run copy:scss'",
    "lint": "eslint src --max-warnings 0"
  },
  "peerDependencies": {
    "react": "^19"
  },
  "devDependencies": {
    "@repo/eslint-config": "*",
    "@repo/tailwind-config": "*",
    "@repo/typescript-config": "*",
    "@tailwindcss/cli": "^4.1.5",
    "@types/react": "^19.1.0",
    "chokidar-cli": "^3.0.0",
    "copyfiles": "^2.4.1",
    "eslint": "^9.31.0",
    "react-icons": "^5.5.0",
    "tailwindcss": "^4.1.5",
    "typescript": "5.8.2"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@repo/utils": "*",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cva": "^0.0.0",
    "lucide-react": "^0.544.0",
    "shadcn": "^3.2.1",
    "tailwind-merge": "^3.3.1",
    "tsc-alias": "^1.8.16",
    "tw-animate-css": "^1.3.8",
    "typescript-plugin-css-modules": "^5.2.0"
  }
}
