{
  "name": "@repo/utils",
  "version": "0.0.0",
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    "./*": {
      "types": "./dist/*.d.ts",
      "default": "./dist/*.js"
    },
    "./**/*": {
      "types": "./dist/**/*.d.ts",
      "default": "./dist/**/*.js"
    }
  },
  "license": "GPL-2.0-only",
  "scripts": {
    "build": "tsc && tsc-alias",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "dev": "tsc --watch & tsc-alias --watch",
    "lint": "eslint src --max-warnings 0"
  },
  "dependencies": {
    "@repo/eslint-config": "0.0.0",
    "@repo/typescript-config": "0.0.0",
    "minimatch": "^10.0.3",
    "typescript": "^5.4.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.45.0",
    "eslint": "^9.31.0",
    "glob": "^13.0.0",
    "tsc-alias": "^1.8.16",
    "vitest": "^4.0.16"
  }
}
