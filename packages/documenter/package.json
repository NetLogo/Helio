{
  "name": "@repo/documenter",
  "version": "0.0.0",
  "sideEffects": [
    "**/*.css",
    "**/*.scss"
  ],
  "files": [
    "dist"
  ],
  "exports": {
    "./*": {
      "types": "./dist/*.d.ts",
      "default": "./dist/*.js"
    },
    "./**/*": {
      "types": "./dist/**/*.d.ts",
      "default": "./dist/**/*.js"
    }
  },
  "license": "MIT",
  "scripts": {
    "build": "tsc && tsc-alias",
    "check-types": "tsc --noEmit",
    "dev": "tsc --watch & tsc-alias --watch",
    "lint": "eslint src --max-warnings 0"
  },
  "peerDependencies": {
    "react": "^19"
  },
  "devDependencies": {
    "@repo/eslint-config": "*",
    "@repo/tailwind-config": "*",
    "@repo/typescript-config": "*",
    "@types/react": "^19.1.0",
    "@typescript-eslint/eslint-plugin": "^8.45.0",
    "eslint": "^9.31.0",
    "typescript": "5.8.2"
  },
  "dependencies": {
    "@repo/next-utils": "*",
    "@repo/utils": "*",
    "tsc-alias": "^1.8.16"
  }
}
