{
  "extends": "@repo/typescript-config/base.json",
  "compilerOptions": {
    "ignoreDeprecations": "5.0",
    "declaration": true,
    "emitDeclarationOnly": true,
    "outDir": "./dist",
    "baseUrl": ".",
    "paths": {
      "@repo/vue-ui/*": ["./src/*"],
      "@repo/utils/*": ["../utils/src/*"],
      "nitropack/types": ["../../node_modules/nitropack/types"],
      "nitropack/runtime": ["../../node_modules/nitropack/runtime"],
      "nitropack": ["../../node_modules/nitropack"],
      "defu": ["../../node_modules/defu"],
      "h3": ["../../node_modules/h3"],
      "consola": ["../../node_modules/consola"],
      "ofetch": ["../../node_modules/ofetch"],
      "@unhead/vue": ["../../node_modules/@unhead/vue"],
      "@nuxt/devtools": ["../../node_modules/@nuxt/devtools"],
      "@vue/runtime-core": ["../../node_modules/@vue/runtime-core"],
      "@vue/compiler-sfc": ["../../node_modules/@vue/compiler-sfc"],
      "unplugin-vue-router/client": ["../../node_modules/unplugin-vue-router/client"],
      "@nuxt/schema": ["../../node_modules/@nuxt/schema"],
      "nuxt": ["../../node_modules/nuxt"],
      "vite/client": ["../../node_modules/vite/client"],
      "nuxt-site-config": ["../../node_modules/nuxt-site-config"],
      "~": ["../nuxt-core/app"],
      "~/*": ["../nuxt-core/app/*"],
      "@": ["../nuxt-core/app"],
      "@/*": ["../nuxt-core/app/*"],
      "~~": [".."],
      "~~/*": ["../nuxt-core/*"],
      "@@": [".."],
      "@@/*": ["../nuxt-core/*"],
      "#shared": ["../nuxt-core/shared"],
      "#shared/*": ["../nuxt-core/shared/*"],
      "#app": ["../../node_modules/nuxt/dist/app"],
      "#app/*": ["../../node_modules/nuxt/dist/app/*"],
      "vue-demi": ["../../node_modules/nuxt/dist/app/compat/vue-demi"],
      "#sitemap": ["../../node_modules/@nuxtjs/sitemap/dist/runtime"],
      "#sitemap/*": ["../../node_modules/@nuxtjs/sitemap/dist/runtime/*"],
      "#site-config": ["../../node_modules/nuxt-site-config/dist/runtime"],
      "#site-config/*": ["../../node_modules/nuxt-site-config/dist/runtime/*"],
      "#content/components": ["../nuxt-core/content/components"],
      "#content/manifest": ["../nuxt-core/content/manifest"],
      "#mdc-configs": ["../nuxt-core/mdc-configs"],
      "#mdc-highlighter": ["../nuxt-core/mdc-highlighter"],
      "#mdc-imports": ["../nuxt-core/mdc-imports"],
      "#ui": ["../../node_modules/@nuxt/ui/dist/runtime"],
      "#ui/*": ["../../node_modules/@nuxt/ui/dist/runtime/*"],
      "#color-mode-options": ["../nuxt-core/color-mode-options.mjs"],
      "#og-image": ["../../node_modules/nuxt-og-image/dist/runtime"],
      "#og-image/*": ["../../node_modules/nuxt-og-image/dist/runtime/*"],
      "#og-image-cache": ["../../node_modules/nuxt-og-image/dist/runtime/server/og-image/cache/lru"],
      "#nuxt-og-image-utils": ["../../node_modules/nuxt-og-image/dist/runtime/shared"],
      "#vue-router": ["../../node_modules/vue-router"],
      "#unhead/composables": ["../../node_modules/nuxt/dist/head/runtime/composables"],
      "#imports": ["../nuxt-core/imports"],
      "#app-manifest": ["../nuxt-core/manifest/meta/48268d78-a154-4a21-8f29-915e347d3df6"],
      "#components": ["../nuxt-core/components"],
      "#build": ["../nuxt-core/.nuxt"],
      "#build/*": ["../nuxt-core/.nuxt/*"]
    },
    "allowArbitraryExtensions": true,
    "types": ["node"],
    "jsx": "preserve",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "target": "ESNext",
    "allowJs": true,
    "resolveJsonModule": true,
    "moduleDetection": "force",
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitOverride": true,
    "module": "preserve",
    "noEmit": true,
    "lib": ["ESNext", "dom", "dom.iterable", "webworker"],
    "jsxImportSource": "vue",
    "moduleResolution": "node",
    "useDefineForClassFields": true,
    "noImplicitThis": true,
    "allowSyntheticDefaultImports": true
  },
  "include": ["src/**/*", "**/*.d.ts", "../nuxt-core/.nuxt/nuxt.d.ts"],
  "exclude": ["node_modules", "dist"]
}
