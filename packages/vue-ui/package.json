{
  "name": "@repo/vue-ui",
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": "^22.0.0"
  },
  "sideEffects": [
    "**/*.css",
    "**/*.scss"
  ],
  "files": [
    "src",
    "assets"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./styles.scss": "./src/styles.scss",
    "./navbar": "./src/components/navbar/index.ts",
    "./footer": "./src/components/footer/index.ts",
    "./catalog": "./src/components/catalog/index.ts",
    "./assets/*": "./assets/*",
    "./HOC/*": "./src/HOC/*",
    "./composables/*": {
      "default": "./src/composables/*",
      "types": "./dist/composables/*.d.ts"
    },
    "./widgets/*": {
      "default": "./src/widgets/*",
      "types": "./src/widgets/*.d.ts"
    },
    "./**/*": {
      "default": [
        "./src/**/*.ts",
        "./src/**/*.vue"
      ],
      "types": "./dist/**/*.d.ts"
    },
    "./*": "./src/*.ts"
  },
  "license": "MIT",
  "scripts": {
    "emit-types": "yarn run check-types && vue-tsc --declaration --emitDeclarationOnly --outDir dist",
    "check-types": "vue-tsc --noEmit",
    "lint": "eslint src --max-warnings 0",
    "setup": "bash scripts/setup.sh"
  },
  "peerDependencies": {
    "radix-vue": "1.9.17",
    "reka-ui": "^2.6.0",
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@eslint/css": "^0.14.1",
    "@nuxt/kit": "^4.2.1",
    "@nuxt/schema": "^4.2.1",
    "@nuxt/ui": "^4.0.1",
    "@repo/eslint-config": "*",
    "@repo/utils": "*",
    "@types/node": "^22.0.0",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vueuse/core": "^14.0.0",
    "class-variance-authority": "^0.7.1",
    "eslint": "^9.31.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.5.1",
    "globals": "^16.5.0",
    "nuxt-og-image": "^5.1.12",
    "nuxt-site-config": "^3.2.11",
    "prettier": "^3.6.2",
    "reka-ui": "^2.6.0",
    "sass": "^1.93.3",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.46.2",
    "vue-eslint-parser": "^10.2.0",
    "vue-router": "^4.6.3",
    "vue-tsc": "^2.0.0"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-vue-next": "^0.544.0",
    "radix-vue": "1.9.17",
    "motion-v": "^1.7.4",
    "reka-ui": "^2.6.0",
    "tailwind-merge": "^3.3.1",
    "tailwindcss-animate": "^1.0.7",
    "tw-animate-css": "^1.4.0",
    "vue": "^3.4.0"
  }
}
