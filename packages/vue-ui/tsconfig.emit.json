{
  "extends": "@repo/typescript-config/base.json",
  "compilerOptions": {
    "declaration": true,
    "emitDeclarationOnly": true,
    "noCheck": true,
    "isolatedModules": false,
    "outDir": "./dist",
    "rootDir": "./src",
    "paths": {
      "@repo/vue-ui/*": ["./src/*"]
    },
    "types": ["node", "./vue-shims.d.ts"],
    "jsx": "preserve"
  },
  "include": ["src/**/*", "*.d.ts"],
  "exclude": ["node_modules", "dist"]
}
