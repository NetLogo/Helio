{
  "name": "@repo/nuxt-core",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "exports": {
    "./nuxt.config.ts": "./nuxt.config.ts",
    "./nuxt/tsconfig.json": "./.nuxt/tsconfig.json"
  },
  "scripts": {
    "init": "nuxt prepare",
    "nuxt:build": "nuxt build",
    "nuxt:dev": "nuxt dev --port 3002",
    "nuxt:dev:no-autogen": "sh -c 'NO_AUTOGEN=true nuxt dev --port 3002'",
    "nuxt:dev:watch": "nuxt dev --port 3002 --dotenv .env.development",
    "nuxt:dev:no-autogen:watch": "sh -c 'NO_AUTOGEN=true nuxt dev --port 3002 --dotenv .env.development'",
    "nuxt:generate": "nuxt prepare && nuxt generate",
    "nuxt:preview": "nuxt preview",
    "nuxt:postinstall": "nuxt prepare",
    "nuxt:prepare": "nuxt prepare",
    "check-types": "nuxi typecheck",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "node-version": "node -v && npm -v",
    "turbo:postinstall": "nuxt prepare"
  },
  "dependencies": {
    "nuxt": "^4.1.2",
    "nuxt-gtag": "4.1.0",
    "nuxt-link-checker": "4.3.6",
    "nuxt-og-image": "^5.1.12",
    "nuxt-svgo": "4.2.6",
    "reka-ui": "^2.6.0",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.4.0",
    "vue": "^3.5.24",
    "vue-router": "^4.6.3",
    "@nuxt/content": "^3.7.1",
    "@nuxt/eslint": "1.10.0",
    "@nuxt/fonts": "0.12.1",
    "@nuxt/icon": "2.0.0",
    "@nuxt/ui": "^4.2.1",
    "@nuxtjs/google-fonts": "3.2.0",
    "@nuxtjs/sitemap": "7.4.7",
    "@repo/common-data": "1.0.0",
    "@repo/eslint-config": "0.0.0",
    "@repo/netlogo-docs": "0.0.0",
    "@repo/tailwind-config": "0.0.0",
    "@repo/template": "0.0.0",
    "@repo/typescript-config": "0.0.0",
    "@repo/utils": "0.0.0",
    "@repo/vue-ui": "1.0.0",
    "@repo/nuxt-core": "0.0.0"
  },
  "devDependencies": {
    "@nuxt/kit": "^4.2.1",
    "@repo/nuxt-content-assets": "1.5.0",
    "@repo/markdown": "0.0.0",
    "turbo-meta-utilities": "^1.0.1",
    "typescript": "^5.4.0",
    "zod": "^4.1.12",
    "sass": "^1.93.3",
    "eslint": "^9.31.0"
  }
}
