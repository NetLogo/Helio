{
  "name": "@repo/modeling-commons-shared",
  "version": "0.0.0",
  "type": "module",
  "files": [
    "dist",
    "src"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./*": {
      "types": "./src/*",
      "default": "./dist/*.js"
    },
    "./**/*": {
      "types": "./src/**/*",
      "default": "./dist/**/*.js"
    }
  },
  "license": "GPL-2.0-only",
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "check-types": "tsc --noEmit",
    "lint": "eslint src --max-warnings 0"
  },
  "dependencies": {
    "typescript": "^5.4.0"
  },
  "devDependencies": {
    "@repo/eslint-config": "0.0.0",
    "@repo/typescript-config": "0.0.0",
    "@types/node": "^22.0.0",
    "eslint": "^9.31.0",
    "typescript": "^5.4.0",
    "vite": "^7.2.4"
  }
}
