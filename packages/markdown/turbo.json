{
  "$schema": "https://turborepo.com/schema.json",
  "extends": [
    "//"
  ],
  "tasks": {
    "build": {
      "dependsOn": [
        "build:styles",
        "build:components",
        "@repo/utils#build",
        "^build"
      ]
    },
    "build:styles": {
      "outputs": [
        "dist/**",
        "^build"
      ]
    },
    "build:components": {
      "outputs": [
        "dist/**",
        "^build"
      ]
    }
  }
}