{
  "name": "@repo/markdown",
  "version": "0.0.0",
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./*": {
      "import": "./dist/*.js",
      "types": "./dist/*.d.ts"
    }
  },
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "tsc --watch & tsc-alias --watch",
    "build": "tsc && tsc-alias",
    "check-types": "tsc --noEmit",
    "lint": "eslint src --max-warnings 0"
  },
  "devDependencies": {
    "@repo/eslint-config": "*",
    "@repo/typescript-config": "*",
    "@types/ini": "^4.1.1",
    "@types/markdown-it": "^14.1.2",
    "@types/mustache": "^4.2.6",
    "chokidar-cli": "^3.0.0",
    "copyfiles": "^2.4.1",
    "eslint": "^9.31.0",
    "tsc-alias": "^1.8.16",
    "typescript": "5.8.2"
  },
  "dependencies": {
    "axios": "^1.11.0",
    "chevron": "^0.2.0",
    "fast-xml-parser": "^5.2.5",
    "ini": "^5.0.0",
    "markdown-it": "^14.1.0",
    "mustache": "^4.2.0",
    "yaml": "^2.8.1",
    "zod": "^4.0.15"
  }
}
