{
  "name": "@repo/netlogo-docs",
  "version": "0.0.0",
  "private": true,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./helpers": {
      "types": "./src/helpers/index.ts",
      "import": "./dist/esm/helpers/index.js",
      "require": "./dist/cjs/helpers/index.js"
    },
    "./helpers-node": {
      "types": "./src/helpers-node/index.ts",
      "import": "./dist/esm/helpers-node/index.js",
      "require": "./dist/cjs/helpers-node/index.js"
    },
    "./*": {
      "types": "./src/*/index.ts",
      "import": "./dist/esm/*/index.js",
      "require": "./dist/cjs/*/index.js"
    }
  },
  "license": "UNLICENSED",
  "scripts": {
    "build:esm": "tsc && tsc-alias",
    "build:cjs": "tsc -p tsconfig.cjs.json && tsc-alias -p tsconfig.cjs.json",
    "build": "yarn run build:esm && yarn run build:cjs",
    "check-types": "tsc --noEmit",
    "dev:components": "tsc --watch & tsc-alias --watch",
    "lint": "eslint src --max-warnings 0",
    "test": "vitest run"
  },
  "peerDependencies": {},
  "devDependencies": {
    "@repo/eslint-config": "0.0.0",
    "@repo/tailwind-config": "0.0.0",
    "@repo/template": "0.0.0",
    "@repo/typescript-config": "0.0.0",
    "@repo/utils": "0.0.0",
    "@typescript-eslint/eslint-plugin": "^8.45.0",
    "eslint": "^9.31.0",
    "glob": "^13.0.0",
    "jsdom": "^25.0.0",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.4.0",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.0.16"
  },
  "dependencies": {
    "slugify": "^1.6.6",
    "tsc-alias": "^1.8.16"
  }
}